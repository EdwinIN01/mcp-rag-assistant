# LLM API（兼容 OpenAI 接口，支持 Qwen/DeepSeek/OpenAI 等）
# 不配置也能跑：Web UI 会降级为只展示检索片段
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-ws-H.EMMRDMP.lzLc.MEQCIFQJb6nlLn8wKEJlFF_hTEKDYq0mnC91Pmvtrg-OPpNUAiBoj1Vj35adDyE9go5ZYuuy5JeZdGLXdFB5grmfUBD8ZA
LLM_MODEL=qwen-plus

# Embedding（API 方式，与本地 Embedding 二选一）
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=sk-ws-H.EMMRDMP.lzLc.MEQCIFQJb6nlLn8wKEJlFF_hTEKDYq0mnC91Pmvtrg-OPpNUAiBoj1Vj35adDyE9go5ZYuuy5JeZdGLXdFB5grmfUBD8ZA
EMBEDDING_MODEL=text-embedding-v3

# 本地 Embedding（推荐，避免联网）
USE_LOCAL_EMBEDDING=true
# 默认用本地缓存的 bge-base-zh-v1.5
LOCAL_EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5

# HuggingFace 离线模式（避免请求 HuggingFace 官网）
HF_HUB_OFFLINE=1

# 重排模型（可选，本地没有则自动跳过重排）
RERANKER_MODEL=BAAI/bge-reranker-base

# 向量库
CHROMA_PERSIST_DIR=./data/chroma

# 文档目录
DOCS_DIR=./data/docs
